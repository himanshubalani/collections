  },
  {
    "id": "YXWPEAAAQBAJ",
    "title": "Kafka on the Shore",
    "image": "http://books.google.com/books/content?id=YXWPEAAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api",
    "type": "BOOKS",
    "description": "A metaphysical novel following a teenage runaway, Kafka Tamura, and an aging man, Nakata, whose mysterious connection leads them through a world where cats talk, fish fall from the sky, and spirits cross between realms.",
    "author": "Haruki Murakami",
